// this is checkerboard-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
if (pickLoop == 0) {
  background(0);
  for (int y = 0; y <height; y +=100) {
    for (int t = 0; t <width; t += 100) {
      square(t, y, 50);
    }
  }
  for (int y = 0; y <height; y +=100) {
    for (int t = 0; t <width; t += 100) {
      square(t+50, y+50, 50);
    }
  }
}

// this is for the big circles-------------------------------------------------------------------------------------------------------
if (pickLoop == 1) {
  for (int y = 0; y <30000; y += 125) {
    for (int t = 0; t <30000; t += 125) {
      noFill();

      stroke(0);
      circle(t, y, 150);
      circle(t+75, y+75, 150);
    }
  }
}



//for the triangles----------------------------------------------------------------------------------------------------------

if (pickLoop == 2) {
  for (int y = 0; y <10000; y += 100) {
    for (int t = 0; t <10000; t += 100) {
      noFill();

      stroke(225);
      strokeWeight(5);
      fill(0);
      triangle(t, y, t+50, y, t+50, y+50);
      triangle(t, y+50, t, y+100, t+50, y+50);
      triangle(t+50, y+50, t+50, y+100, t+100, y+100);
      triangle(t+100, y, t+100, y+50, t+50, y+50);
    }
  }
}



